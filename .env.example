# 바로목 애플리케이션 설정 (.env 템플릿)
# 필요에 따라 수정하고 .env로 저장하세요

# 앱 기본 정보
APP_NAME=바로목
APP_VERSION=0.1.0

# UI 설정
WINDOW_WIDTH=1280
WINDOW_HEIGHT=800
WINDOW_MIN_WIDTH=800
WINDOW_MIN_HEIGHT=600

# 웹캠 설정
CAMERA_INDEX=0
CAMERA_FPS=30
CAMERA_RESOLUTION_WIDTH=1280
CAMERA_RESOLUTION_HEIGHT=720

# 알림 설정
ENABLE_SOUND_ALERT=true
ENABLE_POPUP_ALERT=true
POPUP_POSITION=top
ALERT_SOUND_VOLUME=70
ALERT_COOLDOWN_SECONDS=3.0

# 자동 시작 설정
AUTO_START_DETECTION=false

# 로그 설정
LOG_LEVEL=INFO
# LOG_FILE=logs/barorok.log
